# Consulta Faixa_Renda
WITH base AS (
    SELECT 'Setembro' AS mes, C01011 FROM tb_setembro
    UNION ALL
    SELECT 'Outubro' AS mes, C01011 FROM tb_outubro
    UNION ALL
    SELECT 'Novembro' AS mes, C01011 FROM tb_novembro
),

faixa AS (
    SELECT 
        mes,
        CASE 
            WHEN C01011 = '00' THEN '0 - 100'
            WHEN C01011 = '01' THEN '101 - 300'
            WHEN C01011 = '02' THEN '301 - 600'
            WHEN C01011 = '03' THEN '601 - 800'
            WHEN C01011 = '04' THEN '801 - 1.600'
            WHEN C01011 = '05' THEN '1.601 - 3.000'
            WHEN C01011 = '06' THEN '3.001 - 10.000'
            WHEN C01011 = '07' THEN '10.001 - 50.000'
            WHEN C01011 = '08' THEN '50.001 - 100.000'
            WHEN C01011 = '09' THEN 'Mais de 100.000'
            ELSE 'Não aplicável'
        END AS faixa_renda
    FROM base
),

contagem AS (
    SELECT 
        mes,
        faixa_renda,
        COUNT(*) AS qtd
    FROM faixa
    GROUP BY mes, faixa_renda
)

SELECT 
    faixa_renda,
    SUM(qtd) AS Total
FROM contagem
GROUP BY faixa_renda
ORDER BY faixa_renda;

# Consulta Setor_Trabalho
WITH base AS (
    SELECT 'Setembro' AS mes, C007D FROM tb_setembro
    UNION ALL
    SELECT 'Outubro' AS mes, C007D FROM tb_outubro
    UNION ALL
    SELECT 'Novembro' AS mes, C007D FROM tb_novembro
),

atividade AS (
    SELECT 
        mes,
        CASE 
            WHEN C007D = '01' THEN 'Agricultura, pecuária, produção florestal e pesca'
            WHEN C007D = '02' THEN 'Extração de petróleo, carvão mineral e minerais'
            WHEN C007D = '03' THEN 'Indústria de transformação'
            WHEN C007D = '04' THEN 'Eletricidade, gás, água e esgoto'
            WHEN C007D = '05' THEN 'Construção'
            WHEN C007D = '06' THEN 'Comércio'
            WHEN C007D = '07' THEN 'Reparação de veículos'
            WHEN C007D = '08' THEN 'Transporte de passageiros'
            WHEN C007D = '09' THEN 'Transporte de mercadorias'
            WHEN C007D = '10' THEN 'Armazenamento, correios e entregas'
            WHEN C007D = '11' THEN 'Hospedagem'
            WHEN C007D = '12' THEN 'Alimentação'
            WHEN C007D = '13' THEN 'Informação e comunicação'
            WHEN C007D = '14' THEN 'Bancos e seguros'
            WHEN C007D = '15' THEN 'Atividades imobiliárias'
            WHEN C007D = '16' THEN 'Serviços profissionais'
            WHEN C007D = '17' THEN 'Serviços administrativos'
            WHEN C007D = '18' THEN 'Administração pública'
            WHEN C007D = '19' THEN 'Educação'
            WHEN C007D = '20' THEN 'Saúde'
            WHEN C007D = '21' THEN 'Organizações e associações'
            WHEN C007D = '22' THEN 'Atividades artísticas e esportivas'
            WHEN C007D = '23' THEN 'Serviços pessoais'
            WHEN C007D = '24' THEN 'Serviço doméstico'
            WHEN C007D = '25' THEN 'Outros'
            ELSE 'Não aplicável'
        END AS atividade_desc
    FROM base
),

contagem AS (
    SELECT 
        mes,
        atividade_desc,
        COUNT(*) AS qtd
    FROM atividade
    GROUP BY mes, atividade_desc
)

SELECT 
    atividade_desc,
    SUM(qtd) AS soma
FROM contagem
GROUP BY atividade_desc
ORDER BY soma DESC;

