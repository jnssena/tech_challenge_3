# Consulta Qtd_Entrevistados
WITH base AS (
    SELECT UF, V1022 AS Situacao_Domicilio FROM tb_setembro
    UNION ALL
    SELECT UF, V1022 FROM tb_outubro
    UNION ALL
    SELECT UF, V1022 FROM tb_novembro
)

SELECT 
    UF,
    Situacao_Domicilio,
    COUNT(*) AS Qtd_Entrevistas
FROM base
GROUP BY UF, Situacao_Domicilio
ORDER BY UF, Situacao_Domicilio;

