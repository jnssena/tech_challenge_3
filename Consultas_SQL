# Consulta Resultado_Testes
WITH base AS (

    SELECT B009B AS resultado FROM tb_setembro
    UNION ALL
    SELECT B009D FROM tb_setembro
    UNION ALL
    SELECT B009F FROM tb_setembro

    UNION ALL

    SELECT B009B FROM tb_outubro
    UNION ALL
    SELECT B009D FROM tb_outubro
    UNION ALL
    SELECT B009F FROM tb_outubro

    UNION ALL

    SELECT B009B FROM tb_novembro
    UNION ALL
    SELECT B009D FROM tb_novembro
    UNION ALL
    SELECT B009F FROM tb_novembro
)
SELECT 
    CASE resultado
        WHEN '1' THEN 'Positivo'
        WHEN '2' THEN 'Negativo'
        WHEN '3' THEN 'Inconclusivo'
        WHEN '4' THEN 'Ainda não recebeu o resultado'
        WHEN '9' THEN 'Ignorado'
        ELSE 'Não aplicável'
    END AS resultado_teste,
    COUNT(*) AS total
FROM base
GROUP BY 1
ORDER BY total DESC;

# Consulta Medidas_Seguranca
WITH base AS (

    SELECT 'Setembro' AS mes, B011 AS resultado FROM tb_setembro
    UNION ALL
    SELECT 'Outubro', B011 FROM tb_outubro
    UNION ALL
    SELECT 'Novembro', B011 FROM tb_novembro

),

tratado AS (

    SELECT 
        mes,
        CASE resultado
            WHEN '1' THEN 'Vida normal'
            WHEN '2' THEN 'Reduziu contato'
            WHEN '3' THEN 'Sai só se necessário'
            WHEN '4' THEN 'Rigorosamente em casa'
            WHEN '9' THEN 'Ignorado'
            ELSE 'Não aplicável'
        END AS medida
    FROM base

)

SELECT 
    mes,
    medida,
    COUNT(*) AS total
FROM tratado
GROUP BY mes, medida
ORDER BY mes, total DESC;

# Consulta Publico_Privado
WITH base AS (

    SELECT B0042, B0043, B0044, B0045 FROM tb_setembro
    UNION ALL
    SELECT B0042, B0043, B0044, B0045 FROM tb_outubro
    UNION ALL
    SELECT B0042, B0043, B0044, B0045 FROM tb_novembro

)

SELECT 
    SUM(CASE WHEN B0042 = '1' THEN 1 ELSE 0 END +
        CASE WHEN B0043 = '1' THEN 1 ELSE 0 END) AS total_publico,

    SUM(CASE WHEN B0044 = '1' THEN 1 ELSE 0 END +
        CASE WHEN B0045 = '1' THEN 1 ELSE 0 END) AS total_privado

FROM base;